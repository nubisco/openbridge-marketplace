# Postgres password — used by both the db container and the app
# (DATABASE_URL is constructed in docker-compose.yml from this value)
POSTGRES_PASSWORD=change_me_to_a_random_string

# Secret for signing session JWTs (min 32 chars, keep private)
JWT_SECRET=change_me_to_a_long_random_string

# Cron schedule for the npm crawler (default: every 6 hours)
# CRAWLER_SCHEDULE=0 */6 * * *
