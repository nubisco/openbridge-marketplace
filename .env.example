# PostgreSQL connection string
DATABASE_URL=postgres://marketplace:password@localhost:5432/marketplace

# Secret for signing JWT session tokens (min 32 chars)
JWT_SECRET=change_me_to_a_long_random_string

# Postgres password (used by docker-compose)
POSTGRES_PASSWORD=change_me

# Cron schedule for the npm crawler (default: every 6 hours)
CRAWLER_SCHEDULE=0 */6 * * *
