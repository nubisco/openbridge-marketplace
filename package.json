{
  "name": "openbridge-marketplace",
  "version": "1.7.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "bun --watch server/index.ts",
    "dev:crawler": "bun server/crawler.ts",
    "build": "vite build",
    "preview": "vite preview",
    "server:start": "bun server/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality:check": "pnpm run test && pnpm run lint && pnpm run format:check && pnpm run typecheck",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && pnpm run quality:check",
    "pre-push": "pnpm run quality:check"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "server/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "shared/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mts,mjs,scss}": "prettier --write"
  },
  "release": {
    "branches": [
      "master"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]"
        }
      ]
    ]
  },
  "dependencies": {
    "@nubisco/ui": "^1.8.0",
    "dompurify": "^3.3.3",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "marked": "^18.0.0",
    "postgres": "^3.4.9",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/dompurify": "^3.2.0",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.98.0",
    "semantic-release": "^25.0.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6",
    "vitest": "^4.1.1"
  }
}
